# Caddyfile - Fluvius Production

# Chatwoot principal
fluvius.finderbit.com.br {
    reverse_proxy chatwoot:3000
}

# Evolution API
evolution.fluvius.finderbit.com.br {
    reverse_proxy evolution:8080
}

# Chat interno entre agentes
chat.fluvius.finderbit.com.br {
    reverse_proxy internal-chat:4000
}
