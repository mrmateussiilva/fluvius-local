# Fluvius principal
fluvius.finderbit.com.br {
    reverse_proxy 127.0.0.1:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto https
        header_down Location "http://127.0.0.1:3000" "https://fluvius.finderbit.com.br"
    }
}

# Evolution API
evolution.fluvius.finderbit.com.br {
    reverse_proxy 127.0.0.1:8080
}

# Chat interno entre agentes
chat.fluvius.finderbit.com.br {
    reverse_proxy 127.0.0.1:4000
}
