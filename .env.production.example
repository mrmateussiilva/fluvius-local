# ============================================================
# Fluvius — Variáveis de Produção
# Copie este arquivo para .env.production e preencha os valores
# NUNCA commite o .env.production com segredos reais!
# ============================================================

# --- Banco de dados (Postgres) ---
POSTGRES_USER=chatwoot
POSTGRES_PASSWORD=change-me-strong-password
CHATWOOT_POSTGRES_DB=chatwoot
EVOLUTION_POSTGRES_DB=evolution

# --- Fluvius ---
# Gere com: openssl rand -hex 64
CHATWOOT_SECRET_KEY_BASE=change-me-with-openssl-rand-hex-64
CHATWOOT_FRONTEND_URL=https://fluvius.finderbit.com.br
CHATWOOT_DEFAULT_LOCALE=pt_BR
CHATWOOT_ENABLE_ACCOUNT_SIGNUP=false
ALLOW_PRIVATE_WEBHOOK_URLS=true

# Admin inicial criado automaticamente pelo deploy.
CHATWOOT_ADMIN_EMAIL=admin@fluvius.finderbit.com.br
# Gere uma senha forte. Ela sera usada para criar/atualizar o admin no Fluvius.
CHATWOOT_ADMIN_PASSWORD=finderbit3010
CHATWOOT_ADMIN_NAME=Fluvius Admin
CHATWOOT_ACCOUNT_NAME=Fluvius Admin
CHATWOOT_PLATFORM_APP_NAME=Fluvius Provisioner

# Gerados automaticamente pelo deploy. Pode deixar como esta.
CHATWOOT_USER_ACCESS_TOKEN=auto-generated-by-deploy
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_PLATFORM_TOKEN=auto-generated-by-deploy

# --- Chat Interno & Manager ---
INTERNAL_CHAT_PUBLIC_URL=https://chat.fluvius.finderbit.com.br
INTERNAL_CHAT_ALLOWED_ORIGINS=https://fluvius.finderbit.com.br
# URL pública do Fluvius para o onboard exibir links corretos
CHATWOOT_PUBLIC_URL=https://fluvius.finderbit.com.br
# Gere com: openssl rand -hex 32
MANAGER_ADMIN_TOKEN=change-me-long-random-token

# --- SMTP (e-mails de convite de agentes) ---
MAILER_SENDER_EMAIL=Fluvius <no-reply@fluvius.finderbit.com.br>
SMTP_ADDRESS=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_USERNAME=seu-usuario@seu-provedor.com
SMTP_PASSWORD=sua-senha-smtp
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_SSL=false
SMTP_TLS=false

# --- n8n (opcional) ---
N8N_WEBHOOK_URL=https://n8n.seu-dominio.com/webhook/fluvius-events

# --- Evolution API ---
# Gere com: openssl rand -hex 24
EVOLUTION_API_KEY=change-me-strong-api-key
EVOLUTION_SERVER_URL=https://evolution.fluvius.finderbit.com.br
EVOLUTION_SESSION_PHONE_CLIENT=Fluvius

# --- IA (Fluvius Captain) — opcional ---
CAPTAIN_PROVIDER=gemini
OPENAI_API_KEY=
GEMINI_API_KEY=
CAPTAIN_OPEN_AI_MODEL=gpt-4.1-mini
CAPTAIN_OPEN_AI_ENDPOINT=https://api.openai.com
CAPTAIN_GEMINI_MODEL=gemini-2.5-flash
CAPTAIN_GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai
